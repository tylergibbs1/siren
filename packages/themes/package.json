{
  "name": "@siren/themes",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": {
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./tweakcn.css": {
      "style": "./src/tweakcn.css",
      "default": "./src/tweakcn.css"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2"
  }
}
